# ================== SMTP ==================
# Пример для Яндекс 360 для бизнеса на домене pravo.shop:
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=lead@pravo.shop
# Пароль приложения (НЕ основной пароль от почты!)
# Создаётся в id.yandex.ru → Безопасность → Пароли приложений → Почта
SMTP_PASS=xxxxxxxxxxxxxxxx

# Пример для Mail.ru для бизнеса:
# SMTP_HOST=smtp.mail.ru
# SMTP_PORT=465
# SMTP_USER=lead@pravo.shop
# SMTP_PASS=<пароль для внешних приложений>

# ================== АДРЕСА ==================
# Куда шлём заявки
MAIL_TO=lead@pravo.shop
# От кого (должен быть на том же домене, иначе письма пойдут в спам)
MAIL_FROM=lead@pravo.shop
MAIL_FROM_NAME=Сайт ЛИКВИДАТОР

# ================== CORS ==================
# "same-origin" если API и сайт на одном домене (рекомендуется).
# Иначе укажи боевой URL фронта, например https://liquidator.ru
ALLOWED_ORIGIN=same-origin

# ================== АНТИСПАМ ==================
# Макс. заявок с одного IP в час
RATE_LIMIT_PER_HOUR=3

# ================== СЕРВЕР ==================
# Timeweb Cloud Apps сам подставит PORT
PORT=8000

# ================== PREVIEW (черновики SEO-конвейера) ==================
# Если задано - открывается роут /preview с Basic Auth (просмотр drafts/{slug}/article.html).
# Все ответы /preview получают X-Robots-Tag: noindex,nofollow + meta noindex в HTML.
# Если не задано - роут /preview возвращает 503.
PREVIEW_USER=likvidator
PREVIEW_PASSWORD=замени_на_надёжный_пароль
